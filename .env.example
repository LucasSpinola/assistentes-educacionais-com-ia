# Exemplo de variáveis de ambiente.
# Copie este arquivo para .env e preencha apenas o que for usar.
# O caminho padrão dos exemplos usa Ollama local e não precisa de nenhuma chave.

# APIs comerciais (opcionais)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Configuração do Ollama (valores padrão, normalmente não precisam mudar)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Qdrant (usado no módulo avançado de RAG, via Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
